<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="baccportal.controllers.ChangePasswordController">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <Label text="Change Password"
           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">

        <Label text="Current Password:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <HBox spacing="8" GridPane.rowIndex="0" GridPane.columnIndex="1">
            <PasswordField fx:id="currentPasswordField" promptText="Current Password"/>
            <TextField fx:id="currentPasswordTextField" promptText="Current Password" visible="false" managed="false"/>
            <Button fx:id="currentToggleButton" text="Show" onAction="#toggleCurrentPassword"/>
        </HBox>

        <Label text="New Password:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <HBox spacing="8" GridPane.rowIndex="1" GridPane.columnIndex="1">
            <PasswordField fx:id="newPasswordField" promptText="New Password"/>
            <TextField fx:id="newPasswordTextField" promptText="New Password" visible="false" managed="false"/>
            <Button fx:id="newToggleButton" text="Show" onAction="#toggleNewPassword"/>
        </HBox>

        <Label text="Confirm Password:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <HBox spacing="8" GridPane.rowIndex="2" GridPane.columnIndex="1">
            <PasswordField fx:id="confirmPasswordField" promptText="Confirm New Password"/>
            <TextField fx:id="confirmPasswordTextField" promptText="Confirm New Password" visible="false" managed="false"/>
            <Button fx:id="confirmToggleButton" text="Show" onAction="#toggleConfirmPassword"/>
        </HBox>

        <Button text="Update Password" onAction="#handleChangePassword" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

    </GridPane>

    <Label fx:id="statusLabel"/>

</VBox>
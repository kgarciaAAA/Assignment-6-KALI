<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="model.controllers.MainController">

    <Label text="University Registration System"
           style="-fx-font-size: 20px; -fx-font-weight: bold;" />

    <TextField fx:id="studentIdField" promptText="Enter Student ID" />
    <TextField fx:id="sectionIdField" promptText="Enter Section ID" />

    <HBox spacing="10" alignment="CENTER">
        <Button text="Enroll" onAction="#handleEnroll"/>
        <Button text="Refresh Sections" onAction="#handleRefresh"/>
    </HBox>

    <ListView fx:id="sectionListView" prefHeight="300"/>

    <Label fx:id="statusLabel" text="Status: Ready"/>

</VBox>

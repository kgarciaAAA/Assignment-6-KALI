<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="baccportal.controllers.StudentCompletedCoursesController">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <Label text="Completed Courses"
           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <TableView fx:id="completedTable" prefHeight="300">
        <columns>
            <TableColumn fx:id="sectionIdColumn" text="Section ID"/>
            <TableColumn fx:id="courseIdColumn" text="Course ID"/>
            <TableColumn fx:id="courseNameColumn" text="Course Name"/>
            <TableColumn fx:id="instructorColumn" text="Instructor"/>
            <TableColumn fx:id="priceColumn" text="Price"/>
        </columns>
    </TableView>

    <Label fx:id="statusLabel"/>

</VBox>
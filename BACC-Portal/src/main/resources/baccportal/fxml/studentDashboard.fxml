<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600" prefWidth="800"
            xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12"
            fx:controller="baccportal.controllers.StudentDashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #2c3e50;">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>

            <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" text="BACC Student Portal" />

            <Region HBox.hgrow="ALWAYS" />

            <Label fx:id="welcomeLabel" style="-fx-font-size: 14px; -fx-text-fill: white;" text="Welcome" />
        </HBox>
    </top>

    <left>
        <VBox prefWidth="210" spacing="12" style="-fx-background-color: #34495e;">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <Button maxWidth="Infinity" onAction="#showOverview" text="Overview" />
            <Button maxWidth="Infinity" onAction="#showManageCourses" text="Enroll / Drop Course"/>
            <Button maxWidth="Infinity" onAction="#showEnrolledCourses" text="Enrolled Courses" />
            <Button maxWidth="Infinity" onAction="#showCompletedCourses" text="Completed Courses" />
            <Button maxWidth="Infinity" onAction="#showTransactions" text="Transactions" />
            <Button maxWidth="Infinity" onAction="#handleLogout" text="Log out" />
        </VBox>
    </left>

    <center>
        <VBox fx:id="contentBox" spacing="15">
            <padding>
                <Insets bottom="25" left="25" right="25" top="25" />
            </padding>
        </VBox>
    </center>

</BorderPane>
